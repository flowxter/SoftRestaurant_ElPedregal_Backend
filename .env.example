NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/backend_elpedregal
# Si usas Mongo Atlas, reemplaza MONGODB_URI con tu URI de conexión:
# MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/<nombre_base>?retryWrites=true&w=majority
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_SECRET=change-me-too
RESET_TOKEN_EXPIRES_MINUTES=60
BCRYPT_ROUNDS=12
COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_DOMAIN=
# Ajusta el origen según el puerto donde corra tu frontend. 5173 o 5174 son los puertos Vite habituales.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000
